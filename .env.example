# ============================================================
# LexicoTrend FR — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# Ne jamais committer le .env dans Git
# ============================================================

# ── Base de données PostgreSQL ───────────────────────────────
# Nom du conteneur Docker PostgreSQL sur le réseau CasaOS
# (ou "localhost" si exécuté hors Docker)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=lexicotrend
DB_USER=postgres
DB_PASSWORD=votre_mot_de_passe_ici

# ── API Anthropic ────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# Modèle pour la correction OCR couche 3 (moins cher)
ANTHROPIC_MODEL_OCR=claude-haiku-4-5-20251001
# Modèle pour l'interprétation des anomalies
ANTHROPIC_MODEL_ANALYSIS=claude-sonnet-4-6

# ── Seuils et paramètres ─────────────────────────────────────
# Score qualité OCR minimum avant déclenchement de la correction
OCR_QUALITY_THRESHOLD=0.85
# Délais entre requêtes (politesse API)
GALLICA_REQUEST_DELAY=1.5
GUTENBERG_REQUEST_DELAY=2.0

# ── Modèles NLP ──────────────────────────────────────────────
SPACY_MODEL=fr_core_news_md
BYT5_MODEL=google/byt5-base

# ── User-Agents HTTP ─────────────────────────────────────────
GALLICA_USER_AGENT=LexicoTrend-Research/1.0
GUTENBERG_USER_AGENT=LexicoTrend-Research/1.0
